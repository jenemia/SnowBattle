{
  "name": "@snowbattle/server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start:e2e": "node ./scripts/start-e2e-server.mjs",
    "start": "tsx src/server.ts",
    "start:prod": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "npm run build --workspace @snowbattle/shared && vitest run"
  },
  "dependencies": {
    "@colyseus/sdk": "^0.17.40",
    "@colyseus/ws-transport": "^0.17.13",
    "@snowbattle/shared": "0.1.0",
    "colyseus": "^0.17.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0"
  }
}
