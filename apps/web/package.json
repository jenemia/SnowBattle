{
  "name": "@snowbattle/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build --workspace @snowbattle/shared && tsc -p tsconfig.json --noEmit && vite build && node ./scripts/create-spa-fallback.mjs",
    "preview": "vite preview --host localhost --port 4173",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "npm run build --workspace @snowbattle/shared && vitest run --passWithNoTests",
    "playwright:install": "playwright install chromium",
    "test:e2e": "VITE_SERVER_URL=ws://localhost:2569 npm run build && npm run build --workspace @snowbattle/server && playwright test"
  },
  "dependencies": {
    "@colyseus/sdk": "^0.17.40",
    "@sentry/browser": "^10.49.0",
    "@snowbattle/shared": "0.1.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "vite": "^7.1.9"
  }
}
